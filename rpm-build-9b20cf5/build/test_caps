#!/bin/bash
# shellcheck disable=SC2120

cd "$(dirname "$0")" || exit 1
source ./test-functions.sh

check() {
	local "$@"
	cat <<-EOF >"$t/test.spec"
		Name: test
		Version: 0
		Release: 0
		Summary: Test
		Group: Other
		License: CC0
		BuildArch: noarch
		AutoReqProv: no
		%description
		%install
		mkdir -p %buildroot
		touch %buildroot/{a,b,c}
		%files
		%caps(cap_sys_nice=ep) /a
		/b
		%caps(cap_dac_read_search,cap_sys_ptrace=ep) /c
	EOF
	run \
		args="-bb" \
		spec="$t/test.spec" \
		callback=cb_query \
		"$@"
}

topic="caps"
cb_query() {
        re_output="$t/query"
        rpm -q -p "$t/RPM/RPMS/noarch/test-0-0.noarch.rpm" --requires > "$re_output"
}
check re="rpmlib\(FileCaps\)" msg='rpmlib'
cb_query() {
        re_output="$t/query"
        rpm -q -p "$t/RPM/RPMS/noarch/test-0-0.noarch.rpm" --qf '[%{FILENAMES}:%{FILECAPS}\n]' > "$re_output"
}
check re="^/a:cap_sys_nice=ep\n/b:\n/c:cap_dac_read_search,cap_sys_ptrace=ep\n" msg='set caps'
